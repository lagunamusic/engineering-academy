# ============================================================================
# Engineering Academy — variáveis de ambiente
# Copie este arquivo pra .env.local e preencha. NUNCA commite o .env.local real.
# (o .gitignore já ignora .env*)
# ============================================================================

# ---- Supabase ----
# Pegue em: app.supabase.com -> seu projeto -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica

# Service role: SÓ no backend, NUNCA exposta ao browser. Não tem prefixo NEXT_PUBLIC.
# Usada em rotas server-side que precisam furar o RLS com cuidado.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta

# ---- Anthropic (o AI Guide e a avaliação por evidência) ----
# Pegue em: console.anthropic.com -> API Keys. SÓ no backend, nunca no frontend.
ANTHROPIC_API_KEY=sk-ant-sua-chave-secreta

# ---- App ----
# URL base da app (usada no redirect do magic link). Em local, deixe assim.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
